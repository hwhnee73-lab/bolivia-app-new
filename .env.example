# MySQL 설정
MYSQL_DATABASE=bolivia_db
MYSQL_USER=your_db_user
MYSQL_PASSWORD=your_strong_password
MYSQL_ROOT_PASSWORD=your_root_password

# Spring Boot 설정
DB_USER=your_db_user
DB_PASSWORD=your_strong_password
# JWT 시크릿 키 (openssl rand -base64 32 명령어로 생성한 강력한 키 사용)
JWT_SECRET=your_jwt_secret_key_base64_encoded

# 쿠키/CORS 설정
# 로컬 개발 시: localhost / false / http://localhost:3000
# 프로덕션 시: your-domain.com / true / https://your-domain.com
APP_JWT_COOKIE_DOMAIN=localhost
APP_JWT_COOKIE_SECURE=false
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret